{
  "manifest_version": 3,
  "name": "Page Save Bridge",
  "short_name": "page-save",
  "version": "1.0.0",
  "description": "Saves any browser tab to disk via local WebSocket bridge for Claude Code integration.",
  "permissions": [
    "pageCapture",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Save current tab to disk"
    }
  },
  "action": {
    "default_title": "Page Save Bridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
