{
  "manifest_version": 3,
  "name": "Page Save Bridge",
  "short_name": "page-save",
  "version": "2.0.0",
  "description": "AI-optimized browsing assistant. Captures and reduces web content for AI consumption using domain-specific schemas.",
  "permissions": [
    "pageCapture",
    "tabs",
    "activeTab",
    "scripting",
    "alarms",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Save current tab to disk"
    }
  },
  "action": {
    "default_title": "Page Save Bridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["schemas/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
