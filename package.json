{
  "name": "page-save",
  "version": "0.1.0",
  "type": "module",
  "license": "CC0-1.0",
  "description": "Give AI coding assistants the ability to save and read any browser tab — even sites that block automation. Chrome Extension + Node.js bridge.",
  "bin": {
    "page-save": "./bin/page-save.js"
  },
  "files": [
    "src/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "browser",
    "page-save",
    "mhtml",
    "chrome-extension",
    "websocket",
    "csp-bypass"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somethinlike/page-save.git"
  },
  "author": "Ryan Wills <somethinlike@gmail.com>",
  "scripts": {
    "serve": "node --experimental-strip-types src/cli.ts serve",
    "tabs": "node --experimental-strip-types src/cli.ts tabs",
    "save": "node --experimental-strip-types src/cli.ts save",
    "text": "node --experimental-strip-types src/cli.ts text",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "defuddle": "^0.16.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
